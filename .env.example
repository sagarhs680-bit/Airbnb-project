# Copy this file to .env and fill in real values for local development.
# In production, set these via your deploy environment (docker-compose env, K8s secret, etc.).

# App
NODE_ENV=development
PORT=8000
SESSION_SECRET=change-me-to-a-long-random-string

# MongoDB
# Locally without Docker:  mongodb://127.0.0.1:27017/wonderlust
# With docker-compose:     mongodb://mongo:27017/wonderlust
MONGO_URL=mongodb://127.0.0.1:27017/wonderlust

# Cloudinary - rotate the previously committed keys, then put the new ones here
# Option A (recommended): set CLOUDINARY_URL
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUD_NAME=dthkmttjc
CLOUD_API_KEY=517126646699766
# Recommended:
# CLOUD_API_SECRET=your_api_secret_here
#
# Backward compatible with the current repo typo (used by this project code today):
# CLOUD_API_SECRETE=your_api_secret_here
CLOUD_API_SECRET=change-me-to-your-new-cloudinary-api-secret
CLOUD_API_SECRETE=change-me-to-your-new-cloudinary-api-secret
